# Copy this file to .env and add your API keys

# Alpha Vantage - for US 10Y Treasury
# Get free key: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# EIA - for Brent Crude
# Get free key: https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# NewsAPI - for headlines
# Get free key: https://newsapi.org/register
NEWS_API_KEY=

# OpenWeatherMap - for Charlotte weather
# Get free key: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Optional: GasBuddy API (if you have commercial access)
# GASBUDDY_API_KEY=

# TheSportsDB — Sports tab (free test key is 123; optional premium key from https://www.thesportsdb.com/pricing)
# THESPORTSDB_API_KEY=123
