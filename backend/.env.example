# Copy this file to .env and add your API keys

# Alpha Vantage - for Brent Crude & US 10Y Treasury
# Get free key: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=

# NewsAPI - for headlines
# Get free key: https://newsapi.org/register
NEWS_API_KEY=

# OpenWeatherMap - for Charlotte weather
# Get free key: https://openweathermap.org/api
OPENWEATHER_API_KEY=

# Optional: GasBuddy API (if you have commercial access)
# GASBUDDY_API_KEY=
